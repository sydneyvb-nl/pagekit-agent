{
  "name": "pagekit-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Agent-ready open-source website build system for local service businesses.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "validate:brief": "pnpm --filter @pagekit/generator exec tsx src/cli.ts validate",
    "plan": "pnpm --filter @pagekit/generator exec tsx src/cli.ts plan",
    "inspect:vertical": "pnpm --filter @pagekit/generator exec tsx src/cli.ts inspect-vertical"
  },
  "keywords": [
    "agent",
    "website-generator",
    "local-business",
    "seo",
    "astro",
    "webstudio"
  ],
  "pnpm": {
    "overrides": {
      "rollup": "4.60.4",
      "postcss": "8.5.14",
      "tinyexec": "1.1.2",
      "tinyglobby": "0.2.16"
    },
    "overridesComment": "Pin transitive deps (Vite/Vitest's bundler + helpers) to builds that clear the 14-day minimumReleaseAge cooldown; their floating ranges otherwise resolve to very recent releases."
  }
}
