---
import "../styles/global.css";
import {
  themeRootCss,
  navPages,
  footerPages,
  safeJsonLd,
  type PageContent,
  type SiteContent,
  type ResolvedTheme,
} from "../lib/site";

interface Props {
  page: PageContent;
  site: SiteContent;
  theme: ResolvedTheme;
}

const NAV_LABELS: Record<string, string> = {
  home: "Home",
  services: "Services",
  about: "About",
  team: "Team",
  location: "Location",
  faq: "FAQ",
  contact: "Contact",
  privacy: "Privacy",
  cookies: "Cookies",
  terms: "Terms",
};

function navLabel(p: PageContent): string {
  return NAV_LABELS[p.pageType] ?? p.title.split("|")[0]!.trim();
}

const { page, site, theme } = Astro.props;
const nav = navPages(site);
const legal = footerPages(site);
const year = new Date().getFullYear();
---

<!doctype html>
<html lang={site.language}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{page.title}</title>
    <meta name="description" content={page.metaDescription.value} />
    <meta name="robots" content={page.seo.robots} />
    <link rel="canonical" href={page.seo.canonical} />

    <meta property="og:title" content={page.seo.openGraph.title} />
    <meta property="og:description" content={page.seo.openGraph.description} />
    <meta property="og:type" content={page.seo.openGraph.type} />
    <meta property="og:site_name" content={page.seo.openGraph.siteName} />
    <meta property="og:locale" content={page.seo.openGraph.locale} />
    {page.seo.openGraph.url && <meta property="og:url" content={page.seo.openGraph.url} />}
    <meta name="twitter:card" content="summary" />

    {
      page.jsonLd.map((node) => (
        <script type="application/ld+json" set:html={safeJsonLd(node)} />
      ))
    }

    <style set:html={themeRootCss(theme)}></style>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <div class="container">
        <a class="wordmark" href="/">{site.business}</a>
        <nav class="site-nav" aria-label="Main navigation">
          {
            nav.map((p) => (
              <a href={p.route} aria-current={p.route === page.route ? "page" : undefined}>
                {navLabel(p)}
              </a>
            ))
          }
        </nav>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <span>© {year} {site.business}</span>
        {
          legal.length > 0 && (
            <nav aria-label="Legal">
              {legal.map((p) => (
                <a href={p.route}>{navLabel(p)}</a>
              ))}
            </nav>
          )
        }
      </div>
    </footer>
  </body>
</html>
