---
import type { SectionContent } from "../../lib/site";
import Field from "../Field.astro";

interface Props {
  section: SectionContent;
}
const { section } = Astro.props;
---

<section class={section.section.replace(/\./g, "-")}>
  <div class="container">
    {section.heading && <h2><Field field={section.heading} /></h2>}
    {section.body.map((b) => <Field field={b} as="p" />)}
    {
      section.items.length > 0 && (
        <ul class="grid">
          {section.items.map((item) => (
            <li class="card">
              <h3>
                {item.href ? (
                  <a href={item.href}>
                    <Field field={item.title} />
                  </a>
                ) : (
                  <Field field={item.title} />
                )}
              </h3>
              <Field field={item.body} as="p" />
            </li>
          ))}
        </ul>
      )
    }
    {
      section.cta && (
        <p>
          <a class="button" href={section.cta.href}>
            {section.cta.label}
          </a>
        </p>
      )
    }
  </div>
</section>
