---
import type { SectionContent } from "../../lib/site";
import Field from "../Field.astro";

interface Props {
  section: SectionContent;
  headingLevel: "h1" | "h2";
}
const { section, headingLevel } = Astro.props;
const HeadingTag = headingLevel;
// Testimonials are never invented. When the brief supplies none, the section
// shows an honest placeholder rather than fabricated reviews.
---

<section class="testimonials">
  <div class="container">
    {section.heading && (
      <HeadingTag><Field field={section.heading} /></HeadingTag>
    )}
    {
      section.items.length > 0 ? (
        <ul class="grid">
          {section.items.map((item) => (
            <li class="card">
              <blockquote><Field field={item.body} /></blockquote>
              <cite><Field field={item.title} /></cite>
            </li>
          ))}
        </ul>
      ) : (
        <p><span data-placeholder="" title="Placeholder — needs real content">No testimonials added yet.</span></p>
      )
    }
  </div>
</section>
