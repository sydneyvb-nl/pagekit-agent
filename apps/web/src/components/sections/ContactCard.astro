---
import type { SectionContent } from "../../lib/site";
import Field from "../Field.astro";

interface Props {
  section: SectionContent;
  headingLevel: "h1" | "h2";
}
const { section, headingLevel } = Astro.props;
const HeadingTag = headingLevel;
---

<section class="contact-card">
  <div class="container">
    {section.heading && (
      <HeadingTag><Field field={section.heading} /></HeadingTag>
    )}
    <div class="card">
      <ul>
        {section.body.map((b) => <li><Field field={b} /></li>)}
      </ul>
      {
        section.cta && (
          <a class="button" href={section.cta.href}>
            {section.cta.label}
          </a>
        )
      }
    </div>
  </div>
</section>
