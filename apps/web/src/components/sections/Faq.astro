---
import type { SectionContent } from "../../lib/site";
import Field from "../Field.astro";

interface Props {
  section: SectionContent;
  headingLevel: "h1" | "h2";
}
const { section, headingLevel } = Astro.props;
const HeadingTag = headingLevel;
---

<section class="faq">
  <div class="container">
    {section.heading && (
      <HeadingTag><Field field={section.heading} /></HeadingTag>
    )}
    {
      section.items.map((item) => (
        <details>
          <summary><Field field={item.title} /></summary>
          <Field field={item.body} as="p" />
        </details>
      ))
    }
  </div>
</section>
