{
  "name": "@pagekit/generator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Deterministic site planning and validation generator for pagekit-agent.",
  "license": "Apache-2.0",
  "bin": {
    "pagekit": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "cli": "tsx src/cli.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "tsx": "4.22.0",
    "typescript": "6.0.3",
    "vite": "7.3.3",
    "vitest": "4.1.6"
  }
}
